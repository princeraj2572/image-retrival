# Tesseract OCR Configuration
# Windows path (uncomment if on Windows)
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
# Linux/Mac path (uncomment if on Linux/Mac)
# TESSERACT_PATH=/usr/bin/tesseract

# Google Custom Search API Configuration
SEARCH_API_KEY=your_google_custom_search_api_key
SEARCH_ENGINE_ID=your_search_engine_id

# Detection and Matching Thresholds
CONFIDENCE_THRESHOLD=0.5
SIMILARITY_THRESHOLD_HIGH=0.85
SIMILARITY_THRESHOLD_MEDIUM=0.65
SIMILARITY_THRESHOLD_LOW=0.40

# Model Configuration
YOLO_MODEL=yolov8n.pt

# Device Configuration (cpu or cuda)
DEVICE=cpu

# Project Paths
DATA_DIR=./data
MODELS_DIR=./models
OUTPUT_DIR=./outputs

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Gradio UI Configuration
UI_PORT=7860
UI_SHARE=False
